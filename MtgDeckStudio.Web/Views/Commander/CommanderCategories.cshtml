@model MtgDeckStudio.Web.Models.CommanderCategoryViewModel
@{
    var commanderSpecified = !string.IsNullOrWhiteSpace(Model.Request.CommanderName);
    var hasResults = Model.CategorySummaries.Count > 0;
    var showHint = commanderSpecified || !string.IsNullOrWhiteSpace(Model.ErrorMessage);
    var showNoResults = commanderSpecified && !hasResults && string.IsNullOrWhiteSpace(Model.ErrorMessage);
    ViewData["Title"] = "Commander Categories";
}

<section class="hero">
    <h1>Commander Categories</h1>
    <p class="lede">Search for a commander and see which Archidekt categories appear most often in decks that list it as their commander.</p>
</section>

@await Html.PartialAsync("_BusyIndicator")
@await Html.PartialAsync("_DeckToolTabs", Model.ActiveTab)

<div class="warning-banner">
    Commander selections are resolved from the cached Archidekt category database. The results reflect the categories recorded on decks that name the searched card as commander, so you can see what tags players most often assign when the card is leading a list.
</div>

<div class="error-banner @(string.IsNullOrWhiteSpace(Model.ErrorMessage) ? "hidden" : string.Empty)" role="alert" data-api-panel="commander-error">
    <span data-api-field="commander-error-text">@Model.ErrorMessage</span>
</div>

<div class="error-banner hidden" role="alert" data-api-panel="commander-search-error">
    <span data-api-field="commander-search-error-text"></span>
</div>

<form method="post" action="/commander-categories" class="deck-form" data-cache-key="commander-categories" data-validate-lookup data-busy-title="Looking up commander categories" data-busy-message="Querying the cached category store." data-busy-progress="Refreshing cached store|Scanning recent Archidekt decks|Compiling commander categories" data-busy-hold-final-step="true" data-suggestions-type="commander" data-suggestion-api="/api/suggestions/commander">
    @Html.AntiForgeryToken()
    <div class="toolbar">
            <label class="mode-picker flex-grow">
                <span>Commander</span>
                <input id="commander-search-input" list="commander-suggestions" name="CommanderName" value="@Model.Request.CommanderName" placeholder="Bello, Bard of the Bramble" autocomplete="off" required />
            <datalist id="commander-suggestions"></datalist>
        </label>
        <button type="submit" class="run-button" data-enable-on-ready>Show Categories</button>
        <button type="button" class="clear-cache-button" data-clear-cache>Clear</button>
    </div>
    <p class="mode-note">Type at least two letters to see intelligent suggestions for commanders backed by Scryfall.</p>
    <div class="mode-note">
        <span>Click Show Categories to scan Archidekt for another 20 seconds and grow the commander cache.</span>
    </div>
</form>

<div class="info-banner @(showHint ? string.Empty : "hidden")" data-api-panel="commander-hint">
    <p data-api-field="commander-hint-text">
        @if (!string.IsNullOrWhiteSpace(Model.ErrorMessage))
        {
            @Model.ErrorMessage
        }
        else if (!string.IsNullOrWhiteSpace(Model.Request.CommanderName))
        {
            <text>Commander selections are resolved from the cached Archidekt category database. Click Show Categories to scan Archidekt for another 20 seconds and grow the commander cache.</text>
        }
        else
        {
            <text>Enter a commander name and click Show Categories to gather data.</text>
        }
    </p>
</div>

<section class="result-panel @(hasResults ? string.Empty : "hidden")" data-api-panel="commander-results" id="commander-results-anchor">
    <div class="panel-heading">
        <div>
            <h2>Categories for @Model.Request.CommanderName</h2>
            <span class="info-tooltip" title="Categories sorted by how many cached commander decks included this card (descending).">i</span>
            <p data-api-field="commander-cards-count">@Model.CategoryRows.Count cards contributed to this summary.</p>
            <p data-api-field="commander-deck-count">Derived from @Model.HarvestedDeckCount cached decks with @Model.CategorySummaries.Count distinct categories.</p>
            <p data-api-field="commander-card-deck-count">@Model.Request.CommanderName appears in <strong data-api-field="commander-card-count">@Model.CardDeckTotals.TotalDeckCount</strong> cached commander deck(s).</p>
        </div>
    </div>
    <table class="conflicts-table">
        <thead>
            <tr>
                <th>Category</th>
                <th>Inclusion count</th>
                <th>Decks</th>
            </tr>
        </thead>
        <tbody data-api-field="commander-summary-body">
        @foreach (var summary in Model.CategorySummaries)
        {
            <tr>
                <td>@summary.Category</td>
                <td>@summary.Count</td>
                <td>@summary.DeckCount</td>
            </tr>
        }
        </tbody>
    </table>
</section>

<div class="info-banner @(showNoResults ? string.Empty : "hidden")" data-api-panel="commander-no-results">
    <p data-api-field="commander-no-results-text">No commander categories for @Model.Request.CommanderName have been observed in the cached data yet. Run Show Categories again to refresh the cache.</p>
</div>

@section Scripts {
    <script src="~/js/deck-sync.js" asp-append-version="true"></script>
    <script src="~/js/commander-search.js" asp-append-version="true"></script>
    <script src="~/js/category-suggestions.js" asp-append-version="true"></script>
}
