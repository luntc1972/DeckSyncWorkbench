@using MtgDeckStudio.Core.Models
@model MtgDeckStudio.Web.Models.DeckDiffViewModel
@{
    var suggestionMode = Model.SuggestionRequest.Mode;
    var suggestionInputSource = Model.SuggestionRequest.ArchidektInputSource;
    var hasReferenceInput = suggestionMode == CategorySuggestionMode.ReferenceDeck
        && (!string.IsNullOrWhiteSpace(Model.SuggestionRequest.ArchidektUrl) || !string.IsNullOrWhiteSpace(Model.SuggestionRequest.ArchidektText));
    var cardSpecified = !string.IsNullOrWhiteSpace(Model.SuggestionRequest.CardName);
    var hasExact = !string.IsNullOrWhiteSpace(Model.ExactSuggestedCategoriesText);
    var hasInferred = !string.IsNullOrWhiteSpace(Model.InferredCategoriesText);
    var hasEdhrec = !string.IsNullOrWhiteSpace(Model.EdhrecCategoriesText);
    ViewData["Title"] = "Suggest Categories";
}

<section class="hero">
    <h1>Suggest Categories</h1>
    <p class="lede">Look up a single card against an Archidekt deck, the local category store, recent public decks, and then EDHREC if needed.</p>
</section>

@await Html.PartialAsync("_BusyIndicator")
@await Html.PartialAsync("_DeckToolTabs", Model.ActiveTab)

<div class="warning-banner">
    Suggestions are separated by confidence. Cached store results are the default source, exact Archidekt deck matches are optional, and EDHREC themes are weakest.
</div>

<div class="error-banner @(string.IsNullOrWhiteSpace(Model.SuggestionErrorMessage) ? "hidden" : string.Empty)" role="alert" data-api-panel="suggest-error">
    <span data-api-field="suggest-error-text">@Model.SuggestionErrorMessage</span>
</div>

<div class="error-banner hidden" role="alert" data-api-panel="card-search-error">
    <span data-api-field="card-search-error-text"></span>
</div>

<form method="post" action="/suggest-categories" class="deck-form" data-cache-key="suggest-categories" data-validate-lookup data-busy-title="Finding Categories" data-busy-message="Checking the local store, recent Archidekt decks, and fallback sources." data-busy-progress="Refreshing cached store|Scanning recent Archidekt decks|Querying fallback sources" data-busy-hold-final-step="true" data-suggestions-type="card" data-suggestion-api="/api/suggestions/card">
    @Html.AntiForgeryToken()
    <div class="toolbar">
        <label class="mode-picker">
            <span>Lookup mode</span>
            <select name="Mode" required data-default-value="@CategorySuggestionMode.CachedData">
                <option value="@CategorySuggestionMode.CachedData" selected="@(suggestionMode == CategorySuggestionMode.CachedData)">Use cached data</option>
                <option value="@CategorySuggestionMode.ReferenceDeck" selected="@(suggestionMode == CategorySuggestionMode.ReferenceDeck)">Use reference deck</option>
            </select>
        </label>
        <label class="mode-picker flex-grow">
            <span>Card name</span>
            <input type="text" name="CardName" list="card-suggestions" value="@Model.SuggestionRequest.CardName" placeholder="Guardian Project" autocomplete="off" required />
            <datalist id="card-suggestions"></datalist>
        </label>
        <button type="submit" class="run-button" data-enable-on-ready>Suggest</button>
        <button type="button" class="clear-cache-button" data-clear-cache>Clear</button>
    </div>

    <div class="mode-note">
        <span>Cached data is the default. Switch to a reference deck only when you want exact deck-local categories from a specific Archidekt list.</span>
    </div>
    <div class="mode-note">
        <span>Click Suggest to keep scanning Archidekt decks for another 20 seconds and expand the cached category store.</span>
    </div>

    @if (!string.IsNullOrWhiteSpace(Model.SuggestionRequest.CardName) && Model.CardDeckTotals.TotalDeckCount > 0)
    {
        <div class="info-banner">
            <p>The cached store currently contains <strong>@Model.CardDeckTotals.TotalDeckCount</strong> deck(s) featuring @Model.SuggestionRequest.CardName.</p>
        </div>
    }

    <div class="reference-controls @(suggestionMode == CategorySuggestionMode.ReferenceDeck ? string.Empty : "hidden")">
        <label class="mode-picker">
            <span>Reference deck input</span>
            <select name="ArchidektInputSource" required data-default-value="@DeckInputSource.PublicUrl">
                <option value="@DeckInputSource.PublicUrl" selected="@(suggestionInputSource == DeckInputSource.PublicUrl)">Use public deck URL</option>
                <option value="@DeckInputSource.PasteText" selected="@(suggestionInputSource == DeckInputSource.PasteText)">Paste text</option>
            </select>
        </label>

        <div class="url-grid @(suggestionInputSource == DeckInputSource.PublicUrl ? string.Empty : "hidden")" data-suggest-panel="url">
            <label class="field" data-suggest-panel="archidekt-url">
                <span>Archidekt public deck URL</span>
                <input type="url" name="ArchidektUrl" value="@Model.SuggestionRequest.ArchidektUrl" placeholder="https://archidekt.com/decks/..." />
            </label>
        </div>

        <div class="field-grid @(suggestionInputSource == DeckInputSource.PasteText ? string.Empty : "hidden")" data-suggest-panel="text">
            <label class="field" data-suggest-panel="archidekt-text">
                <span>Archidekt export text</span>
                <textarea name="ArchidektText" spellcheck="false">@Model.SuggestionRequest.ArchidektText</textarea>
            </label>
        </div>
    </div>
</form>

<div class="info-banner @(cardSpecified ? string.Empty : "hidden")" data-api-panel="lookup-hint">
    <p data-api-field="lookup-hint-text">
        @if (!string.IsNullOrWhiteSpace(Model.NoSuggestionsMessage))
        {
            @Model.NoSuggestionsMessage
        }
        else if (cardSpecified)
        {
            <text>The cached store tracks Archidekt categories that appear on decks containing @Model.SuggestionRequest.CardName. Click Suggest to keep scanning public decks for another 20 seconds so those categories can populate.</text>
        }
        else
        {
            <text>Enter a card name and click Suggest to see category suggestions.</text>
        }
    </p>
</div>

<div class="info-banner @(Model.CardDeckTotals.TotalDeckCount > 0 && cardSpecified ? string.Empty : "hidden")" data-api-panel="cache-info">
    <p data-api-field="cache-info-text">The cached store currently contains <strong data-api-field="cache-info-count">@Model.CardDeckTotals.TotalDeckCount</strong> deck(s) featuring @Model.SuggestionRequest.CardName.</p>
</div>

<section class="result-panel retry-panel @(Model.NoSuggestionsFound ? string.Empty : "hidden")" data-api-panel="no-suggestions">
    <div class="panel-heading">
        <div>
            <h2>No Suggestions Found</h2>
            <p data-api-field="no-suggestions-text">@Model.NoSuggestionsMessage</p>
        </div>
        <button type="button" class="run-button" data-api-action="retry">Check Again</button>
    </div>
</section>

<section class="stack">
    <section class="result-panel summary-panel @(string.IsNullOrWhiteSpace(Model.SuggestionSourceSummary) ? "hidden" : string.Empty)" data-api-panel="source-summary">
        <strong>Source used</strong>
        <p data-api-field="source-summary-text">@Model.SuggestionSourceSummary</p>
    </section>

    <section class="result-panel @(hasReferenceInput ? string.Empty : "hidden")" data-api-panel="exact">
        <div class="panel-heading">
            <div>
                <h2>Exact Deck Match</h2>
                <p data-api-field="exact-context">@Model.ExactSuggestionContextText</p>
            </div>
            <button type="button" class="copy-button" data-copy-target="exact-suggested-categories-output">Copy</button>
        </div>
        <textarea id="exact-suggested-categories-output" data-api-field="exact-text" readonly spellcheck="false">@Model.ExactSuggestedCategoriesText</textarea>
    </section>

    <section class="result-panel inferred-panel @(hasInferred ? string.Empty : "hidden")" data-api-panel="inferred" id="cached-store-matches">
        <div class="panel-heading">
            <div>
                <h2>Cached Store Matches</h2>
                <span class="info-tooltip" title="These categories are ordered by how many cached decks contained the card (descending).">i</span>
                <p data-api-field="inferred-context">@Model.InferredSuggestionContextText</p>
                <p data-api-field="cache-info-detail">@if (Model.CardDeckTotals.TotalDeckCount > 0) { <text>@Model.CardDeckTotals.TotalDeckCount deck(s) in the cache include @Model.SuggestionRequest.CardName.</text> }</p>
            </div>
            <button type="button" class="copy-button" data-copy-target="inferred-categories-output">Copy</button>
        </div>
        <textarea id="inferred-categories-output" data-api-field="inferred-text" readonly spellcheck="false">@Model.InferredCategoriesText</textarea>
    </section>

    <section class="result-panel edhrec-panel nested-panel @(hasEdhrec ? string.Empty : "hidden")" data-api-panel="edhrec">
        <div class="panel-heading">
            <div>
                <h2>EDHREC Themes</h2>
                <p data-api-field="edhrec-context">@Model.EdhrecSuggestionContextText</p>
            </div>
            <button type="button" class="copy-button" data-copy-target="edhrec-categories-output">Copy</button>
        </div>
        <textarea id="edhrec-categories-output" data-api-field="edhrec-text" readonly spellcheck="false">@Model.EdhrecCategoriesText</textarea>
    </section>
</section>

@section Scripts {
    <script src="~/js/deck-sync.js" asp-append-version="true"></script>
    <script src="~/js/card-search.js" asp-append-version="true"></script>
    <script src="~/js/category-suggestions.js" asp-append-version="true"></script>
}
