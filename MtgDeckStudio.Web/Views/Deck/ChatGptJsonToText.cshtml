@model MtgDeckStudio.Web.Models.ChatGptJsonTextViewModel
@{
    ViewData["Title"] = "Response Formatter";
}

<section class="hero">
    <h1>Response Formatter</h1>
    <p class="lede">Paste a final JSON response from ChatGPT and convert it into readable text blocks you can review or copy.</p>
</section>

@await Html.PartialAsync("_BusyIndicator")
@await Html.PartialAsync("_DeckToolTabs", Model.ActiveTab)

@if (!string.IsNullOrWhiteSpace(Model.ErrorMessage))
{
    <div class="error-banner" role="alert">@Model.ErrorMessage</div>
}

<div class="info-banner">
    This tool accepts raw JSON or a fenced <code>```json</code> code block and rewrites it into readable text sections.
</div>

<form method="post" action="/chatgpt-json-to-text" class="deck-form" data-cache-key="chatgpt-json-to-text" data-busy-title="Converting ChatGPT JSON" data-busy-message="Formatting the JSON into readable text.">
    @Html.AntiForgeryToken()
    <label class="field">
        <span>ChatGPT JSON</span>
        <textarea name="JsonInput" spellcheck="false">@Model.Request.JsonInput</textarea>
    </label>
    <div class="toolbar">
        <button type="submit" class="run-button">Convert to Text</button>
        <button type="button" class="clear-cache-button" data-clear-cache data-clear-href="/chatgpt-json-to-text">Clear</button>
    </div>
</form>

@if (!string.IsNullOrWhiteSpace(Model.FormattedText) || !string.IsNullOrWhiteSpace(Model.PrettyJson))
{
    <section class="stack">
        @if (!string.IsNullOrWhiteSpace(Model.FormattedText))
        {
            <section class="result-panel">
                <div class="panel-heading">
                    <div>
                        <h2>Formatted Text</h2>
                        <p>Readable text generated from the JSON structure.</p>
                    </div>
                    <button type="button" class="copy-button" data-copy-target="chatgpt-json-formatted-output">Copy</button>
                </div>
                <textarea id="chatgpt-json-formatted-output" readonly spellcheck="false">@Model.FormattedText</textarea>
            </section>
        }

        @if (!string.IsNullOrWhiteSpace(Model.PrettyJson))
        {
            <section class="result-panel">
                <div class="panel-heading">
                    <div>
                        <h2>Extracted JSON</h2>
                        <p>The JSON payload extracted from the ChatGPT response.</p>
                    </div>
                    <button type="button" class="copy-button" data-copy-target="chatgpt-json-raw-output">Copy</button>
                </div>
                <textarea id="chatgpt-json-raw-output" readonly spellcheck="false">@Model.PrettyJson</textarea>
            </section>
        }
    </section>
}

@section Scripts {
    <script src="~/js/deck-sync.js" asp-append-version="true"></script>
}
