@using MtgDeckStudio.Web.Models
@model DeckPageTab

@{
    var deckToolsActive = Model is DeckPageTab.Sync or DeckPageTab.Convert;
    var categoriesActive = Model is DeckPageTab.SuggestCategories or DeckPageTab.CommanderCategories;
    var referenceActive = Model is DeckPageTab.CardLookup or DeckPageTab.MechanicLookup;
    var chatGptActive = Model is DeckPageTab.ChatGptPackets or DeckPageTab.ChatGptJsonToText;
}

<nav class="tool-nav" aria-label="Deck tools" data-tool-nav>
    <div class="tool-nav__group @(deckToolsActive ? "is-active" : string.Empty)" data-tool-nav-group>
        <button type="button" class="tool-nav__trigger" aria-expanded="false" aria-haspopup="true" data-tool-nav-trigger>
            Deck Tools
        </button>
        <div class="tool-nav__dropdown">
            <a class="tool-nav__link @(Model == DeckPageTab.Sync ? "is-active" : string.Empty)" href="/">Deck Sync</a>
            <a class="tool-nav__link @(Model == DeckPageTab.Convert ? "is-active" : string.Empty)" href="/convert">Convert Deck</a>
        </div>
    </div>
    <div class="tool-nav__group @(categoriesActive ? "is-active" : string.Empty)" data-tool-nav-group>
        <button type="button" class="tool-nav__trigger" aria-expanded="false" aria-haspopup="true" data-tool-nav-trigger>
            Categories
        </button>
        <div class="tool-nav__dropdown">
            <a class="tool-nav__link @(Model == DeckPageTab.SuggestCategories ? "is-active" : string.Empty)" href="/suggest-categories">AI Category Suggestions</a>
            <a class="tool-nav__link @(Model == DeckPageTab.CommanderCategories ? "is-active" : string.Empty)" href="/commander-categories">Category Reference</a>
        </div>
    </div>
    <div class="tool-nav__group @(referenceActive ? "is-active" : string.Empty)" data-tool-nav-group>
        <button type="button" class="tool-nav__trigger" aria-expanded="false" aria-haspopup="true" data-tool-nav-trigger>
            Reference
        </button>
        <div class="tool-nav__dropdown">
            <a class="tool-nav__link @(Model == DeckPageTab.CardLookup ? "is-active" : string.Empty)" href="/card-lookup">Card Lookup</a>
            <a class="tool-nav__link @(Model == DeckPageTab.MechanicLookup ? "is-active" : string.Empty)" href="/mechanic-lookup">Mechanic Rules</a>
        </div>
    </div>
    <div class="tool-nav__group @(chatGptActive ? "is-active" : string.Empty)" data-tool-nav-group>
        <button type="button" class="tool-nav__trigger" aria-expanded="false" aria-haspopup="true" data-tool-nav-trigger>
            ChatGPT
        </button>
        <div class="tool-nav__dropdown">
            <a class="tool-nav__link @(Model == DeckPageTab.ChatGptPackets ? "is-active" : string.Empty)" href="/chatgpt-packets">ChatGPT Analysis</a>
            <a class="tool-nav__link @(Model == DeckPageTab.ChatGptJsonToText ? "is-active" : string.Empty)" href="/chatgpt-json-to-text">Response Formatter</a>
        </div>
    </div>
</nav>
