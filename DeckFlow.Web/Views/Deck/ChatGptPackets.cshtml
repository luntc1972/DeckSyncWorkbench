@model DeckFlow.Web.Models.ChatGptDeckViewModel
@{
    ViewData["Title"] = "ChatGPT Analysis";
    var currentStep = Math.Clamp(Model.Request.WorkflowStep, 1, 5);
    var commanderBrackets = DeckFlow.Web.Models.CommanderBracketCatalog.Options;
    var questionBuckets = DeckFlow.Web.Models.AnalysisQuestionCatalog.Buckets;
    var analysisFollowUpPrompt = """
Answer my follow-up questions first.

Then regenerate the full updated deck_profile JSON so it reflects:
- your latest conclusions and corrections
- the additional questions I asked directly in chat
- the answers you gave to those additional questions

Update the question_answers array so it includes those additional direct-chat questions and answers in the correct order alongside the original requested questions.

Return only the updated deck_profile inside a fenced ```json code block.
Do not omit any fields from the schema.
""";
    var selectedQuestionSet = new HashSet<string>(Model.Request.SelectedAnalysisQuestions, StringComparer.OrdinalIgnoreCase);
    var openBuckets = new HashSet<string>(
        DeckFlow.Web.Models.AnalysisQuestionCatalog.Buckets
            .Where(b => b.Questions.Any(q => selectedQuestionSet.Contains(q.Id)))
            .Select(b => b.Id),
        StringComparer.OrdinalIgnoreCase);
}

<section class="hero">
    <h1>ChatGPT Analysis</h1>
    <p class="lede">Paste your deck, choose your analysis questions, generate the prompt, and paste back the results. The set-upgrade step is optional.</p>
</section>

@await Html.PartialAsync("_BusyIndicator")
@await Html.PartialAsync("_DeckToolTabs", Model.ActiveTab)

@if (!string.IsNullOrWhiteSpace(Model.ErrorMessage))
{
    <div class="error-banner" role="alert">@Model.ErrorMessage</div>
}

<div class="info-banner chatgpt-global-note">
    Follow the steps in order. Each step tells you what to paste into ChatGPT and what to paste back into this page.
</div>

@if (!string.IsNullOrWhiteSpace(Model.SavedArtifactsDirectory))
{
    <div class="info-banner chatgpt-global-note">
        Saved packet artifacts to <code>@Model.SavedArtifactsDirectory</code>.
    </div>
}

@if (!string.IsNullOrWhiteSpace(Model.TimingSummary))
{
    <details class="timing-summary">
        <summary>Generation timing</summary>
        <pre>@Model.TimingSummary</pre>
    </details>
}

<div class="error-banner hidden" data-chatgpt-validation-error role="alert"></div>

<div class="toolbar chatgpt-page-toolbar">
    <div class="chatgpt-layout-picker" data-chatgpt-ui-mode-picker>
        <div class="chatgpt-layout-picker__copy">
            <strong>Workflow layouts</strong>
            <span>Try different levels of guidance without changing the underlying prompt flow.</span>
        </div>
        <div class="chatgpt-layout-picker__actions">
            <button type="button" class="clear-cache-button" data-chatgpt-ui-mode-button="guided">Full workflow</button>
            <button type="button" class="clear-cache-button" data-chatgpt-ui-mode-button="focused">Compact workflow</button>
            <button type="button" class="clear-cache-button" data-chatgpt-ui-mode-button="expert">Advanced workflow</button>
        </div>
    </div>

</div>

<form method="post" class="deck-form chatgpt-packets-form" data-cache-key="chatgpt-packets" data-chatgpt-packets-form data-chatgpt-current-step="@currentStep" data-chatgpt-ui-mode="guided" data-set-options-url="@Url.Content("~/api/set-options")" data-busy-title="Building ChatGPT Packets" data-busy-message="Resolving the deck and generating prompt files.">
    @Html.AntiForgeryToken()
    <input type="hidden" name="WorkflowStep" value="@currentStep" data-chatgpt-workflow-step />

    <details class="result-panel chatgpt-import-panel desktop-only">
        <summary>Import saved session from folder</summary>
        <p>Paste a path to a saved <code>Documents\MTG Deck Studio\ChatGPT Analysis\&lt;commander&gt;\&lt;timestamp&gt;</code> folder. The saved <code>40-deck-profile.json</code> and <code>51-set-upgrade-response.json</code> files will be loaded and rendered. You can also use a path relative to the <code>ChatGPT Analysis</code> root.</p>
        <label class="field">
            <span>Saved artifacts folder</span>
            <input type="text" name="ImportArtifactsPath" value="@Model.Request.ImportArtifactsPath" placeholder="Commander Name\20260416-140000" data-chatgpt-import-path />
        </label>
        <div class="toolbar chatgpt-step-actions">
            <button type="submit" class="run-button" data-chatgpt-submit-step="5" data-chatgpt-import-submit>Import and Render</button>
        </div>
    </details>

    <div class="chatgpt-step-nav" role="tablist" aria-label="ChatGPT packet workflow steps">
        <button type="button" class="chatgpt-step-tab" role="tab" id="chatgpt-step-tab-1" aria-controls="chatgpt-step-panel-1" aria-selected="false" tabindex="-1" data-chatgpt-show-step="1">Step 1: Deck Setup</button>
        <button type="button" class="chatgpt-step-tab" role="tab" id="chatgpt-step-tab-2" aria-controls="chatgpt-step-panel-2" aria-selected="false" tabindex="-1" data-chatgpt-show-step="2">Step 2: Analysis</button>
        <button type="button" class="chatgpt-step-tab" role="tab" id="chatgpt-step-tab-3" aria-controls="chatgpt-step-panel-3" aria-selected="false" tabindex="-1" data-chatgpt-show-step="3">Step 3: Analysis Results</button>
        <button type="button" class="chatgpt-step-tab" role="tab" id="chatgpt-step-tab-4" aria-controls="chatgpt-step-panel-4" aria-selected="false" tabindex="-1" data-chatgpt-show-step="4">Step 4: Set Upgrades (Optional)</button>
        <button type="button" class="chatgpt-step-tab" role="tab" id="chatgpt-step-tab-5" aria-controls="chatgpt-step-panel-5" aria-selected="false" tabindex="-1" data-chatgpt-show-step="5">Step 5: Set Upgrade Results (Optional)</button>
    </div>
    <section class="result-panel chatgpt-step-panel chatgpt-workflow-setup" role="tabpanel" id="chatgpt-step-panel-1" aria-labelledby="chatgpt-step-tab-1" data-chatgpt-step="1" data-chatgpt-setup-panel>
        <div class="chatgpt-step-heading">
            <div>
                <p class="chatgpt-step-eyebrow">Step 1</p>
                <h2>Paste the deck once for the whole workflow</h2>
                <p>This deck input powers the analysigs packet and the optional set-upgrade packet.</p>
            </div>
            <span class="chatgpt-step-badge">Required</span>
        </div>

        <label class="chatgpt-question-option desktop-only">
            <input type="checkbox" name="SaveArtifactsToDisk" value="true" @(Model.Request.SaveArtifactsToDisk ? "checked" : null) />
            <span>Save generated prompts, pasted JSON responses, and hidden additional context to disk under <code>Documents/MTG Deck Studio/ChatGPT Analysis</code></span>
        </label>

        <label class="field">
            <span>Deck URL or deck text</span>
            <textarea name="DeckSource" spellcheck="false">@Model.Request.DeckSource</textarea>
            <small class="sync-column__hint">Required. Paste a public Moxfield or Archidekt URL, or paste deck export text directly.</small>
        </label>
        <div class="toolbar chatgpt-step-actions">
            <button type="button" class="clear-cache-button" data-clear-cache data-clear-href="@Url.Content("~/chatgpt-packets")">Clear</button>
            <div class="chatgpt-step-note">You only need to paste the deck here once. After that, move through the workflow tabs below.</div>
            <button type="button" class="run-button" data-chatgpt-next-step="2">Next: Analysis</button>
        </div>
    </section>

    <section class="result-panel chatgpt-step-panel" role="tabpanel" id="chatgpt-step-panel-2" aria-labelledby="chatgpt-step-tab-2" data-chatgpt-step="2">
        <div class="chatgpt-step-heading">
            <div>
                <p class="chatgpt-step-eyebrow">Step 2</p>
                <h2>Choose the analysis questions and generate the analysis packet</h2>
                <p>Select the Commander bracket you want to target, then choose the question buckets or individual questions that should be answered in the analysis prompt.</p>
            </div>
            <span class="chatgpt-step-badge">Customize the analysis</span>
        </div>

        <div class="chatgpt-instructions">
            <strong>What you do:</strong>
            <ol>
                <li>Choose the target Commander bracket.</li>
                <li>Select one or more question buckets, individual questions, or both.</li>
                <li>Optionally include sideboard and/or maybeboard cards as candidate references.</li>
                <li>Click <code>Generate Analysis Packet</code>.</li>
                <li>Copy <code>analysis.txt</code> and paste it into ChatGPT.</li>
                <li>Ask ChatGPT to return the <code>deck_profile</code> JSON inside a fenced <code>```json</code> code block.</li>
                <li>Move to Step 3 to paste the returned JSON and view a formatted analysis summary. Step 4 is optional for set-specific upgrade suggestions.</li>
            </ol>
        </div>

        <div class="info-banner chatgpt-helper-panel">
            <strong>How to push back on ChatGPT's conclusions</strong>
            <p>If ChatGPT makes a bad assumption, challenge the specific conclusion before you paste the <code>deck_profile</code> JSON back here. Ask it to revise the analysis and return an updated <code>deck_profile</code> JSON that reflects your corrections.</p>
            <p>Examples: "Re-evaluate this as Bracket 2 Core, not Bracket 3 Upgraded." "You overstated the combo finishers; the deck wins primarily through combat." "Card X is not a weak slot because it is part of the recursion engine."</p>
            <p>Best practice: keep the conversation in ChatGPT going until the analysis reflects your corrections, then copy only the latest corrected <code>deck_profile</code> JSON into Step 3.</p>
        </div>

        <section class="result-panel nested-panel">
            <div class="panel-heading">
                <div>
                    <h3>Optional Follow-up JSON Refresh Prompt</h3>
                    <p>Use this later only if you asked additional questions in ChatGPT after the first analysis response and need it to rebuild the updated <code>deck_profile</code> JSON.</p>
                </div>
                <button type="button" class="copy-button" data-copy-target="analysis-follow-up-output">Copy</button>
            </div>
            <textarea id="analysis-follow-up-output" readonly spellcheck="false">@analysisFollowUpPrompt</textarea>
        </section>

        <label class="field">
            <span>Target Commander bracket <small>(required)</small></span>
            <select name="TargetCommanderBracket" required aria-required="true">
                <option value="">Select a target bracket (required)</option>
                @foreach (var bracket in commanderBrackets)
                {
                    <option value="@bracket.Value" selected="@(string.Equals(Model.Request.TargetCommanderBracket, bracket.Value, StringComparison.OrdinalIgnoreCase))">@bracket.Label</option>
                }
            </select>
            <small class="sync-column__hint">Required. The analysis prompt will include the official Commander bracket expectation and turn pacing for the bracket you select.</small>
        </label>
        <details class="result-panel nested-panel">
            <summary>Analysis context</summary>
            <div class="chatgpt-context-note">
                <p>These fields do not change the deck parser. They are extra instructions that get inserted into the analysis and set-upgrade prompts.</p>
                <ul>
                    <li><strong>Format</strong> keeps the analysis and upgrade prompts in the right rules context.</li>
                    <li><strong>Deck name</strong> gives the prompts a stable label and is also saved with the packet artifacts.</li>
                    <li><strong>Strategy notes</strong> tell ChatGPT what the deck is trying to do so it weighs the list against your intended game plan.</li>
                    <li><strong>Meta notes</strong> tell ChatGPT what kinds of tables or threats you expect, which changes how it judges weaknesses and upgrades.</li>
                </ul>
                <p>If you leave these blank, the prompts still work. ChatGPT will infer more from the decklist alone.</p>
            </div>
            <div class="sync-columns">
                <label class="field">
                    <span>Format</span>
                    <input type="text" name="Format" value="@Model.Request.Format" />
                </label>
                <label class="field">
                    <span>Deck name</span>
                    <input type="text" name="DeckName" value="@Model.Request.DeckName" />
                </label>
            </div>
            <label class="field">
                <span>Strategy notes</span>
                <textarea name="StrategyNotes" spellcheck="false">@Model.Request.StrategyNotes</textarea>
            </label>
            <label class="field">
                <span>Meta notes</span>
                <textarea name="MetaNotes" spellcheck="false">@Model.Request.MetaNotes</textarea>
            </label>
        </details>
        <div class="result-panel nested-panel">
            <label class="chatgpt-question-option">
                <input type="checkbox" name="IncludeSideboardInAnalysis" value="true" @(Model.Request.IncludeSideboardInAnalysis ? "checked" : "") />
                <span>Include sideboard cards as candidate references in the analysis prompt</span>
            </label>
            <label class="chatgpt-question-option">
                <input type="checkbox" name="IncludeMaybeboardInAnalysis" value="true" @(Model.Request.IncludeMaybeboardInAnalysis ? "checked" : "") />
                <span>Include maybeboard cards as candidate references in the analysis prompt</span>
            </label>
            <small class="sync-column__hint">Current-deck card definitions are always included. These options only add authoritative references for optional candidate cards and keep them labeled as candidates, not active deck cards.</small>
        </div>
        <section class="chatgpt-question-picker">
            <div class="chatgpt-question-picker__header">
                <h3>Analysis questions</h3>
                <p>Select a whole bucket to check all questions under it, or choose individual questions manually.</p>
            </div>
            <div class="chatgpt-question-buckets">
                @foreach (var bucket in questionBuckets)
                {
                    var bucketId = $"bucket-{bucket.Id}";
                    var bucketOpen = openBuckets.Contains(bucket.Id);
                    var bucketAriaExpanded = bucketOpen ? "true" : "false";
                    var bucketQuestionsClass = bucketOpen ? "chatgpt-question-bucket__questions" : "chatgpt-question-bucket__questions hidden";
                    <section class="result-panel nested-panel chatgpt-question-bucket">
                        <div class="chatgpt-question-bucket__header">
                            <label class="chatgpt-question-bucket__label">
                                <input type="checkbox" data-question-bucket="@bucket.Id" id="@bucketId" />
                                <span>@bucket.Label</span>
                            </label>
                            <button type="button" class="chatgpt-question-bucket__toggle" data-bucket-toggle="@bucket.Id" aria-expanded="@bucketAriaExpanded"></button>
                        </div>
                        <div class="@bucketQuestionsClass" data-bucket-questions="@bucket.Id">
                            @foreach (var question in bucket.Questions)
                            {
                                <label class="chatgpt-question-option">
                                    <input
                                        type="checkbox"
                                        name="SelectedAnalysisQuestions"
                                        value="@question.Id"
                                        data-question-option="@bucket.Id"
                                        checked="@(Model.Request.SelectedAnalysisQuestions.Contains(question.Id, StringComparer.OrdinalIgnoreCase))" />
                                    <span>@question.Text</span>
                                </label>
                            }
                            @if (bucket.Id == "optimization-upgrades")
                            {
                                <label class="field chatgpt-budget-field hidden" data-budget-question-field>
                                    <span>Budget amount for budget upgrade question</span>
                                    <input type="text" name="BudgetUpgradeAmount" value="@Model.Request.BudgetUpgradeAmount" inputmode="decimal" />
                                    <small class="sync-column__hint">Used when you select "What are the best upgrades under $X budget?" Enter just the amount, for example <code>50</code>.</small>
                                </label>
                            }
                            @if (bucket.Id == "card-level")
                            {
                                <label class="field chatgpt-card-specific-field hidden" data-card-specific-question-field>
                                    <span>Card name for card-specific questions</span>
                                    <input type="text" name="CardSpecificQuestionCardName" value="@Model.Request.CardSpecificQuestionCardName" />
                                    <small class="sync-column__hint">This is used when you select "Is [card] worth including?" or "What are better alternatives to [card]?"</small>
                                </label>
                            }
                            @if (bucket.Id == "deck-versioning")
                            {
                                <label class="field">
                                    <span>Decklist export format <small>(required for category questions)</small></span>
                                    <select name="DecklistExportFormat">
                                        <option value="" selected="@(string.IsNullOrEmpty(Model.Request.DecklistExportFormat))">Select export format</option>
                                        <option value="moxfield" selected="@(string.Equals(Model.Request.DecklistExportFormat, "moxfield", StringComparison.OrdinalIgnoreCase))">Moxfield</option>
                                        <option value="archidekt" selected="@(string.Equals(Model.Request.DecklistExportFormat, "archidekt", StringComparison.OrdinalIgnoreCase))">Archidekt</option>
                                    </select>
                                    <small class="sync-column__hint">Choose which deck builder you will paste the generated lists into. When assigning or updating categories, you must choose Moxfield or Archidekt and ChatGPT should return the decklist in a fenced <code>```text</code> block.</small>
                                </label>
                                <label class="chatgpt-question-option">
                                    <input type="checkbox" name="IncludeCardVersions" value="true" @(Model.Request.IncludeCardVersions ? "checked" : "") />
                                    <span>
                                        Include card versions (set code &amp; collector number) for retained cards
                                        <small class="sync-column__hint" style="display:block;margin-top:0.2rem">When checked, the original deck's set code and collector number are provided to ChatGPT so it can preserve the exact printing for any card kept in a generated deck version.</small>
                                    </span>
                                </label>
                                <label class="field hidden" data-preferred-categories-field>
                                    <span>Preferred category names (optional)</span>
                                    <textarea name="PreferredCategories" rows="4" spellcheck="false">@Model.Request.PreferredCategories</textarea>
                                    <small class="sync-column__hint">One category name per line. ChatGPT will use these names when assigning categories and will only create new ones when none of the preferred names fit.</small>
                                </label>
                                <label class="field">
                                    <span>Protected cards (optional)</span>
                                    <textarea name="ProtectedCards" rows="4" spellcheck="false">@Model.Request.ProtectedCards</textarea>
                                    <small class="sync-column__hint">One card name per line. These cards will always be kept in every generated deck version or upgrade path. They may still appear as suggested cuts in the general analysis.</small>
                                </label>
                            }
                        </div>
                    </section>
                }
            </div>
        </section>
        <label class="field">
            <span>Additional freeform question (optional)</span>
            <textarea name="FreeformQuestion" rows="3" spellcheck="false" placeholder="Type any additional question or instruction to include in the analysis prompt…">@Model.Request.FreeformQuestion</textarea>
            <small class="sync-column__hint">This question is appended to the list of selected analysis questions in the generated prompt.</small>
        </label>
        <div class="toolbar chatgpt-step-actions">
            <button type="submit" class="run-button" data-chatgpt-submit-step="2">Generate Analysis Packet</button>
        </div>

        @if (!string.IsNullOrWhiteSpace(Model.SuggestedChatTitle))
        {
            <section class="result-panel nested-panel">
                <div class="panel-heading">
                    <div>
                        <h3>Suggested ChatGPT conversation title</h3>
                        <p>Rename your ChatGPT conversation to this before pasting the prompt.</p>
                    </div>
                    <button type="button" class="copy-button" data-copy-target="suggested-chat-title">Copy</button>
                </div>
                <input id="suggested-chat-title" type="text" readonly value="@Model.SuggestedChatTitle" />
            </section>
        }

        @if (!string.IsNullOrWhiteSpace(Model.InputSummary))
        {
            <section class="result-panel nested-panel summary-panel">
                <h3>Deck Summary</h3>
                <pre spellcheck="false">@Model.InputSummary</pre>
            </section>
        }

        @if (!string.IsNullOrWhiteSpace(Model.AnalysisPromptText))
        {
            <section class="result-panel nested-panel">
                <div class="panel-heading">
                    <div>
                        <h3>analysis.txt</h3>
                        <p>Paste this into ChatGPT for the main deck analysis. It requests prose analysis plus a structured <code>deck_profile</code> JSON object.</p>
                    </div>
                    <button type="button" class="copy-button" data-copy-target="analysis-output">Copy</button>
                </div>
                <textarea id="analysis-output" readonly spellcheck="false" data-chatgpt-result-anchor>@Model.AnalysisPromptText</textarea>
            </section>
        }

        @if (!string.IsNullOrWhiteSpace(Model.ReferenceText))
        {
            <section class="result-panel nested-panel">
                <div class="panel-heading">
                    <div>
                        <h3>reference.txt</h3>
                        <p>Support context for the analysis prompt. It contains the authoritative card and mechanic references already embedded into <code>analysis.txt</code>, so you usually do not need to paste it into ChatGPT separately.</p>
                    </div>
                    <button type="button" class="copy-button" data-copy-target="reference-output">Copy</button>
                </div>
                <textarea id="reference-output" readonly spellcheck="false">@Model.ReferenceText</textarea>
            </section>
        }

        @if (!string.IsNullOrWhiteSpace(Model.DeckProfileSchemaJson))
        {
            <details class="result-panel nested-panel">
                <summary>Show expected JSON format for deck-profile-schema.json</summary>
                <div class="panel-heading">
                    <div>
                        <h3>deck-profile-schema.json</h3>
                        <p>ChatGPT should return a <code>deck_profile</code> JSON object matching this schema.</p>
                    </div>
                    <button type="button" class="copy-button" data-copy-target="deck-profile-schema-output">Copy</button>
                </div>
                <textarea id="deck-profile-schema-output" readonly spellcheck="false">@Model.DeckProfileSchemaJson</textarea>
            </details>
        }

        <div class="chatgpt-step-footer">
            <button type="button" class="clear-cache-button" data-chatgpt-show-step="1">Back: Deck Setup</button>
            <button type="button" class="run-button" data-chatgpt-next-step="3">Next: Analysis Results</button>
        </div>
    </section>

    <section class="result-panel chatgpt-step-panel" role="tabpanel" id="chatgpt-step-panel-3" aria-labelledby="chatgpt-step-tab-3" data-chatgpt-step="3">
        <div class="chatgpt-step-heading">
            <div>
                <p class="chatgpt-step-eyebrow">Step 3</p>
                <h2>Paste the deck profile JSON and view the analysis results</h2>
                <p>Paste the fenced <code>deck_profile</code> JSON block or raw JSON payload returned from ChatGPT. You can use a saved JSON file here directly without filling out Steps 1 and 2 again.</p>
            </div>
            <span class="chatgpt-step-badge">Review results</span>
        </div>

        <label class="field">
            <span>Deck profile JSON</span>
            <textarea name="DeckProfileJson" spellcheck="false">@Model.Request.DeckProfileJson</textarea>
            <small class="sync-column__hint">Required for rendering the analysis summary and for the optional set-upgrade step. You can paste the fenced <code>```json</code> block directly.</small>
        </label>

        <div class="toolbar chatgpt-step-actions">
            <button type="submit" class="run-button" data-chatgpt-submit-step="3">Render Analysis Summary</button>
        </div>

        @if (Model.AnalysisResponse is not null)
        {
            <section class="result-panel nested-panel summary-panel" data-chatgpt-result-anchor>
                <h3>Analysis Summary</h3>
                <div class="stack">
                    <section class="result-panel nested-panel">
                        <h4>Overview</h4>
                        @if (!string.IsNullOrWhiteSpace(Model.AnalysisResponse.Format))
                        {
                            <p><strong>Format:</strong> @Model.AnalysisResponse.Format</p>
                        }
                        @if (!string.IsNullOrWhiteSpace(Model.AnalysisResponse.Commander))
                        {
                            <p><strong>Commander:</strong> @Model.AnalysisResponse.Commander</p>
                        }
                        @if (!string.IsNullOrWhiteSpace(Model.AnalysisResponse.GamePlan))
                        {
                            <p><strong>Game plan:</strong> @Model.AnalysisResponse.GamePlan</p>
                        }
                        @if (!string.IsNullOrWhiteSpace(Model.AnalysisResponse.Speed))
                        {
                            <p><strong>Speed:</strong> @Model.AnalysisResponse.Speed</p>
                        }
                        @if (Model.AnalysisResponse.PrimaryAxes.Count > 0)
                        {
                            <p><strong>Primary axes:</strong> @string.Join(", ", Model.AnalysisResponse.PrimaryAxes)</p>
                        }
                        @if (Model.AnalysisResponse.SynergyTags.Count > 0)
                        {
                            <p><strong>Synergy tags:</strong> @string.Join(", ", Model.AnalysisResponse.SynergyTags)</p>
                        }
                    </section>

                    <div class="sync-columns">
                        <section class="result-panel nested-panel">
                            <h4>Strengths</h4>
                            <ul>
                                @foreach (var item in Model.AnalysisResponse.Strengths)
                                {
                                    <li>@item</li>
                                }
                            </ul>
                        </section>

                        <section class="result-panel nested-panel">
                            <h4>Weaknesses</h4>
                            <ul>
                                @foreach (var item in Model.AnalysisResponse.Weaknesses)
                                {
                                    <li>@item</li>
                                }
                            </ul>
                        </section>
                    </div>

                    @if (Model.AnalysisResponse.DeckNeeds.Count > 0)
                    {
                        <section class="result-panel nested-panel">
                            <h4>Deck Needs</h4>
                            <ul>
                                @foreach (var item in Model.AnalysisResponse.DeckNeeds)
                                {
                                    <li>@item</li>
                                }
                            </ul>
                        </section>
                    }

                    @if (Model.AnalysisResponse.WeakSlots.Count > 0)
                    {
                        <section class="result-panel nested-panel">
                            <h4>Weak Slots</h4>
                            <ul>
                                @foreach (var slot in Model.AnalysisResponse.WeakSlots)
                                {
                                    <li><strong>@slot.Card</strong> — @slot.Reason</li>
                                }
                            </ul>
                        </section>
                    }

                    @if (Model.AnalysisResponse.QuestionAnswers.Count > 0)
                    {
                        <section class="result-panel nested-panel">
                            <h4>Question Answers</h4>
                            @foreach (var qa in Model.AnalysisResponse.QuestionAnswers)
                            {
                                <div class="result-panel nested-panel" style="margin-bottom:0.5rem">
                                    <p><strong>Q@(qa.QuestionNumber): @qa.Question</strong></p>
                                    <p>@qa.Answer</p>
                                    @if (!string.IsNullOrWhiteSpace(qa.Basis))
                                    {
                                        <p><small>Basis: @qa.Basis</small></p>
                                    }
                                </div>
                            }
                        </section>
                    }

                    @if (Model.AnalysisResponse.DeckVersions.Count > 0)
                    {
                        <section class="result-panel nested-panel">
                            <h4>Deck Versions</h4>
                            @foreach (var version in Model.AnalysisResponse.DeckVersions)
                            {
                                <details class="result-panel nested-panel" style="margin-bottom:0.5rem">
                                    <summary>@version.VersionName</summary>
                                    @if (version.CardsAdded.Count > 0)
                                    {
                                        <p><strong>Cards added:</strong></p>
                                        <ul>
                                            @foreach (var card in version.CardsAdded)
                                            {
                                                <li>@card</li>
                                            }
                                        </ul>
                                    }
                                    @if (version.CardsCut.Count > 0)
                                    {
                                        <p><strong>Cards cut:</strong></p>
                                        <ul>
                                            @foreach (var card in version.CardsCut)
                                            {
                                                <li>@card</li>
                                            }
                                        </ul>
                                    }
                                    @if (!string.IsNullOrWhiteSpace(version.Decklist))
                                    {
                                        <p><strong>Decklist:</strong></p>
                                        <pre spellcheck="false">@version.Decklist</pre>
                                    }
                                </details>
                            }
                        </section>
                    }
                </div>
            </section>
        }

        <div class="chatgpt-step-footer">
            <button type="button" class="clear-cache-button" data-chatgpt-show-step="2">Back: Analysis</button>
            <button type="button" class="run-button" data-chatgpt-next-step="4">Next: Set Upgrades</button>
        </div>
    </section>

    <section class="result-panel chatgpt-step-panel" role="tabpanel" id="chatgpt-step-panel-4" aria-labelledby="chatgpt-step-tab-4" data-chatgpt-step="4">
        <div class="chatgpt-step-heading">
            <div>
                <p class="chatgpt-step-eyebrow">Step 4</p>
                <h2>Optional: Build the set-upgrade packet</h2>
                <p>This step is optional. Use it only when you want set-specific upgrade analysis after the main deck analysis is complete. The deck profile JSON from Step 3 is used automatically.</p>
            </div>
            <span class="chatgpt-step-badge">Optional final step</span>
        </div>

        <div class="chatgpt-instructions">
            <strong>What you do:</strong>
            <ol>
                <li>Select one set, or paste a condensed set packet.</li>
                <li>Click <code>Generate Set Upgrade Packet</code>.</li>
                <li>Paste the returned <code>set-upgrade-analysis.txt</code> into ChatGPT.</li>
                <li>Have ChatGPT return both a fenced <code>```json</code> block for the set analysis data and a fenced <code>```text</code> block named <code>discussion_summary.txt</code> with condensed per-set notes, recommendations, and answers.</li>
            </ol>
        </div>
        <label class="field">
            <span>Select one set to generate a compact set packet</span>
            <select name="SelectedSetCodes" size="12" data-set-options-select data-selected-codes="@string.Join(",", Model.Request.SelectedSetCodes.Take(1))">
            </select>
            <small class="sync-column__hint">Choose a single set here. The tool generates a compact candidate packet instead of a full set dump to keep the ChatGPT prompt sendable.</small>
            <small class="sync-column__hint hidden" data-set-options-error>The Scryfall set catalog could not be loaded right now. You can still paste a condensed set packet manually below.</small>
        </label>
        <label class="field">
            <span>Set upgrade focus</span>
            <select name="SetUpgradeFocus">
                <option value="" selected="@(string.IsNullOrEmpty(Model.Request.SetUpgradeFocus))">Best additions (default)</option>
                <option value="lateral-moves" selected="@(string.Equals(Model.Request.SetUpgradeFocus, "lateral-moves", StringComparison.OrdinalIgnoreCase))">Lateral moves — same role, different card</option>
                <option value="strict-upgrades" selected="@(string.Equals(Model.Request.SetUpgradeFocus, "strict-upgrades", StringComparison.OrdinalIgnoreCase))">Strict upgrades — clearly better than what I have</option>
                <option value="both" selected="@(string.Equals(Model.Request.SetUpgradeFocus, "both", StringComparison.OrdinalIgnoreCase))">Both — lateral moves and strict upgrades</option>
            </select>
            <small class="sync-column__hint">Controls what ChatGPT looks for. Default finds the best adds regardless of type. Lateral moves swap a card for something at a similar power level. Strict upgrades replace a card with something meaningfully better.</small>
        </label>
        <details class="result-panel nested-panel">
            <summary>Show condensed set packet override</summary>
            <label class="field">
                <span>Condensed set packet override</span>
                <textarea name="SetPacketText" spellcheck="false">@Model.Request.SetPacketText</textarea>
                <small class="sync-column__hint">Optional. Leave this blank to use the generated set packet from the selected sets.</small>
            </label>
        </details>
        <div class="toolbar chatgpt-step-actions">
            <button type="submit" class="run-button" data-chatgpt-submit-step="4">Generate Set Upgrade Packet</button>
        </div>

        @if (!string.IsNullOrWhiteSpace(Model.SetUpgradePromptText))
        {
            <section class="result-panel nested-panel">
                <div class="panel-heading">
                    <div>
                        <h3>set-upgrade-analysis.txt</h3>
                        <p>Paste this into ChatGPT after you have a deck profile and a condensed set packet. It tells ChatGPT to return both structured JSON and a condensed discussion summary text block that includes the per-set analysis.</p>
                    </div>
                    <button type="button" class="copy-button" data-copy-target="set-upgrade-output">Copy</button>
                </div>
                <textarea id="set-upgrade-output" readonly spellcheck="false" data-chatgpt-result-anchor>@Model.SetUpgradePromptText</textarea>
            </section>
        }
        <div class="chatgpt-step-footer">
            <button type="button" class="clear-cache-button" data-chatgpt-show-step="3">Back: Analysis Results</button>
            <button type="button" class="run-button" data-chatgpt-next-step="5">Next: Set Upgrade Results</button>
        </div>
    </section>

    <section class="result-panel chatgpt-step-panel" role="tabpanel" id="chatgpt-step-panel-5" aria-labelledby="chatgpt-step-tab-5" data-chatgpt-step="5">
        <div class="chatgpt-step-heading">
            <div>
                <p class="chatgpt-step-eyebrow">Step 5</p>
                <h2>Paste the set-upgrade JSON and view the results</h2>
                <p>Paste the fenced <code>set_upgrade_report</code> JSON block or raw JSON payload returned from ChatGPT. You can use a saved JSON file here directly without filling out earlier steps.</p>
            </div>
            <span class="chatgpt-step-badge">Review results</span>
        </div>

        <label class="field">
            <span>Set upgrade report JSON</span>
            <textarea name="SetUpgradeResponseJson" spellcheck="false">@Model.Request.SetUpgradeResponseJson</textarea>
            <small class="sync-column__hint">Paste the fenced <code>```json</code> block or the raw JSON payload. Surrounding prose (like the <code>discussion_summary.txt</code> text block) is safe to include.</small>
        </label>

        <div class="toolbar chatgpt-step-actions">
            <button type="submit" class="run-button" data-chatgpt-submit-step="5">Render Set Upgrade Results</button>
        </div>

        @if (Model.SetUpgradeResponse is not null)
        {
            <section class="result-panel nested-panel summary-panel" data-chatgpt-result-anchor>
                <h3>Set Upgrade Results</h3>
                <div class="stack">
                    @foreach (var set in Model.SetUpgradeResponse.Sets)
                    {
                        <section class="result-panel nested-panel">
                            <h4>
                                @if (!string.IsNullOrWhiteSpace(set.SetName))
                                {
                                    @set.SetName
                                    @if (!string.IsNullOrWhiteSpace(set.SetCode))
                                    {
                                        <text> (@set.SetCode)</text>
                                    }
                                }
                                else if (!string.IsNullOrWhiteSpace(set.SetCode))
                                {
                                    @set.SetCode
                                }
                                else
                                {
                                    <text>Set</text>
                                }
                            </h4>

                            @if (set.TopAdds.Count > 0)
                            {
                                <section class="result-panel nested-panel">
                                    <h5>Top Adds</h5>
                                    @foreach (var add in set.TopAdds)
                                    {
                                        <div class="result-panel nested-panel" style="margin-bottom:0.5rem">
                                            <p><strong>@add.Card</strong></p>
                                            @if (!string.IsNullOrWhiteSpace(add.Reason))
                                            {
                                                <p>@add.Reason</p>
                                            }
                                            @if (!string.IsNullOrWhiteSpace(add.SuggestedCut))
                                            {
                                                <p><strong>Suggested cut:</strong> @add.SuggestedCut</p>
                                            }
                                            @if (!string.IsNullOrWhiteSpace(add.CutReason))
                                            {
                                                <p><small>@add.CutReason</small></p>
                                            }
                                        </div>
                                    }
                                </section>
                            }

                            @if (set.Traps.Count > 0)
                            {
                                <section class="result-panel nested-panel">
                                    <h5>Traps</h5>
                                    <ul>
                                        @foreach (var trap in set.Traps)
                                        {
                                            <li><strong>@trap.Card</strong>@(string.IsNullOrWhiteSpace(trap.Reason) ? null : $" — {trap.Reason}")</li>
                                        }
                                    </ul>
                                </section>
                            }

                            @if (set.SpeculativeTests.Count > 0)
                            {
                                <section class="result-panel nested-panel">
                                    <h5>Speculative Tests</h5>
                                    <ul>
                                        @foreach (var spec in set.SpeculativeTests)
                                        {
                                            <li><strong>@spec.Card</strong>@(string.IsNullOrWhiteSpace(spec.Reason) ? null : $" — {spec.Reason}")</li>
                                        }
                                    </ul>
                                </section>
                            }
                        </section>
                    }

                    @if (Model.SetUpgradeResponse.FinalShortlist is not null
                         && (Model.SetUpgradeResponse.FinalShortlist.MustTest.Count > 0
                             || Model.SetUpgradeResponse.FinalShortlist.Optional.Count > 0
                             || Model.SetUpgradeResponse.FinalShortlist.Skip.Count > 0))
                    {
                        <section class="result-panel nested-panel">
                            <h4>Final Shortlist</h4>
                            <div class="sync-columns">
                                @if (Model.SetUpgradeResponse.FinalShortlist.MustTest.Count > 0)
                                {
                                    <section class="result-panel nested-panel">
                                        <h5>Must Test</h5>
                                        <ul>
                                            @foreach (var card in Model.SetUpgradeResponse.FinalShortlist.MustTest)
                                            {
                                                <li>@card</li>
                                            }
                                        </ul>
                                    </section>
                                }
                                @if (Model.SetUpgradeResponse.FinalShortlist.Optional.Count > 0)
                                {
                                    <section class="result-panel nested-panel">
                                        <h5>Optional</h5>
                                        <ul>
                                            @foreach (var card in Model.SetUpgradeResponse.FinalShortlist.Optional)
                                            {
                                                <li>@card</li>
                                            }
                                        </ul>
                                    </section>
                                }
                                @if (Model.SetUpgradeResponse.FinalShortlist.Skip.Count > 0)
                                {
                                    <section class="result-panel nested-panel">
                                        <h5>Skip</h5>
                                        <ul>
                                            @foreach (var card in Model.SetUpgradeResponse.FinalShortlist.Skip)
                                            {
                                                <li>@card</li>
                                            }
                                        </ul>
                                    </section>
                                }
                            </div>
                        </section>
                    }
                </div>
            </section>
        }

        <div class="chatgpt-step-footer">
            <button type="button" class="clear-cache-button" data-chatgpt-show-step="4">Back: Set Upgrades</button>
        </div>
    </section>
</form>

@section Scripts {
    <script src="~/js/deck-sync.js" asp-append-version="true"></script>
}
