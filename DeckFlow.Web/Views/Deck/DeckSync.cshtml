@using DeckFlow.Core.Models
@model DeckFlow.Web.Models.DeckDiffViewModel
@{
    var direction = Model.Request.Direction;
    var moxfieldInputSource = Model.Request.MoxfieldInputSource;
    var archidektInputSource = Model.Request.ArchidektInputSource;
    var leftSystem = direction switch
    {
        SyncDirection.ArchidektToArchidekt => "Archidekt",
        _ => "Moxfield",
    };
    var rightSystem = direction switch
    {
        SyncDirection.MoxfieldToMoxfield => "Moxfield",
        _ => "Archidekt",
    };
    var leftIsSource = direction is SyncDirection.MoxfieldToArchidekt or SyncDirection.MoxfieldToMoxfield;
    var sourceName = leftIsSource ? leftSystem : rightSystem;
    var targetName = leftIsSource ? rightSystem : leftSystem;
    var targetUsesArchidektVersion = direction == SyncDirection.MoxfieldToArchidekt;
    targetUsesArchidektVersion = string.Equals(targetName, "Archidekt", StringComparison.OrdinalIgnoreCase);
    var sourceLabelKind = string.Equals(sourceName, "Archidekt", StringComparison.OrdinalIgnoreCase) ? "categories" : "tags";
    var targetLabelKind = string.Equals(targetName, "Archidekt", StringComparison.OrdinalIgnoreCase) ? "categories" : "tags";
    ViewData["Title"] = "Deck Sync";
}

<section class="hero">
    <h1>Deck Sync</h1>
    <p class="lede">Compare or merge two deck exports, including same-platform Moxfield-to-Moxfield and Archidekt-to-Archidekt workflows.</p>
</section>

@await Html.PartialAsync("_BusyIndicator")
@await Html.PartialAsync("_DeckToolTabs", Model.ActiveTab)

<div class="warning-banner">
    Existing target cards stay in place. Sideboard and maybeboard entries are excluded from the comparison and export flow.
</div>

@if (!string.IsNullOrWhiteSpace(Model.ErrorMessage))
{
    <div class="error-banner" role="alert">@Model.ErrorMessage</div>
}

<form id="deck-sync-form" method="post" class="deck-form" data-cache-key="deck-sync" data-busy-title="Running Deck Sync" data-busy-message="Comparing decks and building import output." data-deck-sync-api="@Url.Content("~/api/deck/diff")">
    @Html.AntiForgeryToken()
    <div class="toolbar">
        <div class="direction-group">
            <label class="mode-picker">
                <span>Sync direction</span>
                <select name="Direction">
                    <option value="@SyncDirection.MoxfieldToArchidekt" selected="@(direction == SyncDirection.MoxfieldToArchidekt)">Moxfield to Archidekt</option>
                    <option value="@SyncDirection.ArchidektToMoxfield" selected="@(direction == SyncDirection.ArchidektToMoxfield)">Archidekt to Moxfield</option>
                    <option value="@SyncDirection.MoxfieldToMoxfield" selected="@(direction == SyncDirection.MoxfieldToMoxfield)">Moxfield to Moxfield</option>
                    <option value="@SyncDirection.ArchidektToArchidekt" selected="@(direction == SyncDirection.ArchidektToArchidekt)">Archidekt to Archidekt</option>
                </select>
            </label>
        </div>
        <label class="mode-picker">
            <span>Match mode</span>
            <select name="Mode">
                <option value="@MatchMode.Loose" selected="@(Model.Request.Mode == MatchMode.Loose)">Loose</option>
                <option value="@MatchMode.Strict" selected="@(Model.Request.Mode == MatchMode.Strict)">Strict</option>
            </select>
        </label>
        <label class="mode-picker">
            <span>Category sync</span>
            <select name="CategorySyncMode">
                <option value="@CategorySyncMode.TargetCategories" data-sync-role="category-mode-target" selected="@(Model.Request.CategorySyncMode == CategorySyncMode.TargetCategories)">Use target @targetLabelKind</option>
                <option value="@CategorySyncMode.SourceTags" data-sync-role="category-mode-source" selected="@(Model.Request.CategorySyncMode == CategorySyncMode.SourceTags)">Use source @sourceLabelKind</option>
                <option value="@CategorySyncMode.Combined" selected="@(Model.Request.CategorySyncMode == CategorySyncMode.Combined)">Combine both</option>
            </select>
        </label>
        <button type="submit" class="run-button" data-enable-on-ready>Run Compare</button>
        <button type="button" class="clear-cache-button" data-clear-cache>Clear</button>
    </div>

    <div class="mode-note">
        <span>You can mix input methods. Public URLs are convenient when the deck APIs respond; pasted text is the more reliable fallback.</span>
    </div>

    <div class="sync-columns">
        <section class="sync-column sync-column--moxfield" aria-labelledby="moxfield-panel-title">
            <div class="sync-column__header">
                <p id="moxfield-panel-title" data-sync-role="moxfield-title">@leftSystem</p>
                <span class="sync-column__status" data-sync-role="moxfield-status">
                    @(leftIsSource ? "Source deck" : "Target deck")
                </span>
            </div>
            <p class="sync-column__description" data-sync-role="moxfield-description">Provide the @leftSystem export or public URL for this deck.</p>
            <label class="field">
                <span>Input method</span>
                <select name="MoxfieldInputSource">
                    <option value="@DeckInputSource.PasteText" selected="@(moxfieldInputSource == DeckInputSource.PasteText)">Paste text</option>
                    <option value="@DeckInputSource.PublicUrl" selected="@(moxfieldInputSource == DeckInputSource.PublicUrl)">Use public deck URL</option>
                </select>
            </label>
            <div class="sync-column__body">
                <label class="field sync-column__input-field @(moxfieldInputSource == DeckInputSource.PublicUrl ? string.Empty : "hidden")" data-sync-panel="moxfield-url">
                    <span data-sync-role="moxfield-url-label">@leftSystem public deck URL</span>
                    <input type="url" name="MoxfieldUrl" value="@Model.Request.MoxfieldUrl" placeholder="@(string.Equals(leftSystem, "Archidekt", StringComparison.OrdinalIgnoreCase) ? "https://archidekt.com/decks/..." : "https://moxfield.com/decks/...")" />
                    @if (string.Equals(leftSystem, "Moxfield", StringComparison.OrdinalIgnoreCase))
                    {
                        @await Html.PartialAsync("_DeckFlowBridgeHint")
                    }
                </label>
                <label class="field sync-column__input-field @(moxfieldInputSource == DeckInputSource.PasteText ? string.Empty : "hidden")" data-sync-panel="moxfield-text">
                    <span data-sync-role="moxfield-text-label">@leftSystem export text</span>
                    <textarea name="MoxfieldText" spellcheck="false">@Model.Request.MoxfieldText</textarea>
                    <small class="sync-column__hint" data-sync-role="moxfield-hint">Use this when the @leftSystem deck is @(leftIsSource ? "the source" : "the target").</small>
                    @if (string.Equals(leftSystem, "Moxfield", StringComparison.OrdinalIgnoreCase))
                    {
                        @await Html.PartialAsync("_MoxfieldBulkEditHint")
                    }
                </label>
            </div>
        </section>
        <section class="sync-column sync-column--archidekt" aria-labelledby="archidekt-panel-title">
            <div class="sync-column__header">
                <p id="archidekt-panel-title" data-sync-role="archidekt-title">@rightSystem</p>
                <span class="sync-column__status" data-sync-role="archidekt-status">
                    @(leftIsSource ? "Target deck" : "Source deck")
                </span>
            </div>
            <p class="sync-column__description" data-sync-role="archidekt-description">Provide the @rightSystem export or public URL for this deck.</p>
            <label class="field">
                <span>Input method</span>
                <select name="ArchidektInputSource">
                    <option value="@DeckInputSource.PasteText" selected="@(archidektInputSource == DeckInputSource.PasteText)">Paste text</option>
                    <option value="@DeckInputSource.PublicUrl" selected="@(archidektInputSource == DeckInputSource.PublicUrl)">Use public deck URL</option>
                </select>
            </label>
            <div class="sync-column__body">
                <label class="field sync-column__input-field @(archidektInputSource == DeckInputSource.PublicUrl ? string.Empty : "hidden")" data-sync-panel="archidekt-url">
                    <span data-sync-role="archidekt-url-label">@rightSystem public deck URL</span>
                    <input type="url" name="ArchidektUrl" value="@Model.Request.ArchidektUrl" placeholder="@(string.Equals(rightSystem, "Moxfield", StringComparison.OrdinalIgnoreCase) ? "https://moxfield.com/decks/..." : "https://archidekt.com/decks/...")" />
                    @if (string.Equals(rightSystem, "Moxfield", StringComparison.OrdinalIgnoreCase))
                    {
                        @await Html.PartialAsync("_DeckFlowBridgeHint")
                    }
                </label>
                <label class="field sync-column__input-field @(archidektInputSource == DeckInputSource.PasteText ? string.Empty : "hidden")" data-sync-panel="archidekt-text">
                    <span data-sync-role="archidekt-text-label">@rightSystem export text</span>
                    <textarea name="ArchidektText" spellcheck="false">@Model.Request.ArchidektText</textarea>
                    <small class="sync-column__hint" data-sync-role="archidekt-hint">Use this when the @rightSystem deck is @(leftIsSource ? "the target" : "the source").</small>
                    @if (string.Equals(rightSystem, "Moxfield", StringComparison.OrdinalIgnoreCase))
                    {
                        @await Html.PartialAsync("_MoxfieldBulkEditHint")
                    }
                </label>
            </div>
        </section>
    </div>
</form>

<div id="deck-sync-error" class="error-banner hidden" role="alert"></div>

<div id="deck-sync-results" class="stack @(Model.Diff is null ? "hidden" : string.Empty)">
    <div id="results-anchor"></div>
    <section class="result-panel">
        <h2>Reconciliation Report</h2>
        <pre id="deck-sync-report" spellcheck="false">@Model.ReportText</pre>
    </section>

    <section class="result-panel">
        <div class="panel-heading">
            <div>
                <h2>Add Missing Cards</h2>
                <p>Paste this into <span data-sync-result="target-system">@targetName</span> to add only the cards that are missing from the target deck.</p>
            </div>
            <button type="button" class="copy-button" data-copy-target="delta-output">Copy</button>
        </div>
        <textarea id="delta-output" readonly spellcheck="false">@Model.DeltaText</textarea>
    </section>

    <section class="result-panel">
        <div class="panel-heading">
            <div>
                <h2>Full Deck Export</h2>
                <p>A full export formatted for <span data-sync-result="target-system">@targetName</span>, reusing target printings and board placement where matches already exist.</p>
            </div>
            <button type="button" class="copy-button" data-copy-target="full-import-output">Copy</button>
        </div>
        <textarea id="full-import-output" readonly spellcheck="false">@Model.FullImportText</textarea>
    </section>

<section class="result-panel @(Model.Diff?.PrintingConflicts.Count > 0 ? string.Empty : "hidden")" id="deck-sync-conflicts-js">
        <div class="panel-heading">
            <div>
                <h2>Printing Conflicts</h2>
                <p><span data-sync-result="target-system">@targetName</span> printings stay in place unless you generate a manual checklist for swapping them afterward.</p>
            </div>
        </div>
        <table class="conflicts-table">
            <thead>
                <tr>
                    <th>Card</th>
                    <th id="deck-sync-conflict-target"><span data-sync-result="target-system">@targetName</span></th>
                    <th id="deck-sync-conflict-source"><span data-sync-result="source-system">@sourceName</span></th>
                </tr>
            </thead>
            <tbody id="deck-sync-conflicts-body">
            @if (Model.Diff is not null)
            {
                foreach (var conflict in Model.Diff.PrintingConflicts)
                {
                    var archidektCategorySuffix = string.IsNullOrWhiteSpace(conflict.ArchidektVersion.Category)
                        ? string.Empty
                        : $" [{conflict.ArchidektVersion.Category}]";
                    <tr>
                        <td>@conflict.CardName</td>
                        @if (targetUsesArchidektVersion)
                        {
                            <td>(@conflict.ArchidektVersion.SetCode) @conflict.ArchidektVersion.CollectorNumber@archidektCategorySuffix</td>
                            <td>(@conflict.MoxfieldVersion.SetCode) @conflict.MoxfieldVersion.CollectorNumber</td>
                        }
                        else
                        {
                            <td>(@conflict.MoxfieldVersion.SetCode) @conflict.MoxfieldVersion.CollectorNumber</td>
                            <td>(@conflict.ArchidektVersion.SetCode) @conflict.ArchidektVersion.CollectorNumber@archidektCategorySuffix</td>
                        }
                    </tr>
                }
            }
            </tbody>
        </table>
    </section>

    <details class="result-panel">
        <summary>How to import safely</summary>
        <pre id="deck-sync-instructions" spellcheck="false">@Model.InstructionsText</pre>
    </details>
</div>

@section Scripts {
    <script src="~/js/deck-sync.js" asp-append-version="true"></script>
}

<noscript>
@if (Model.Diff is not null)
{
    <section id="results-anchor" class="stack">
        <section class="result-panel">
            <h2>Reconciliation Report</h2>
            <pre>@Model.ReportText</pre>
        </section>

        <section class="result-panel">
            <div class="panel-heading">
                <div>
                    <h2>Add Missing Cards</h2>
                    <p>Paste this into @targetName to add only the cards that are missing from the target deck.</p>
                </div>
                <button type="button" class="copy-button" data-copy-target="delta-output">Copy</button>
            </div>
            <textarea id="delta-output" readonly spellcheck="false">@Model.DeltaText</textarea>
        </section>

        <section class="result-panel">
            <div class="panel-heading">
                <div>
                    <h2>Full Deck Export</h2>
                    <p>A full export formatted for @targetName, reusing target printings and board placement where matches already exist.</p>
                </div>
                <button type="button" class="copy-button" data-copy-target="full-import-output">Copy</button>
            </div>
            <textarea id="full-import-output" readonly spellcheck="false">@Model.FullImportText</textarea>
        </section>

        @if (Model.Diff.PrintingConflicts.Count > 0)
        {
            <form method="post" action="@Url.Content("~/resolve")" class="result-panel" data-busy-title="Generating Swap Checklist" data-busy-message="Applying your printing choices.">
                @Html.AntiForgeryToken()
                <input type="hidden" name="MoxfieldInputSource" value="@Model.Request.MoxfieldInputSource" />
                <input type="hidden" name="ArchidektInputSource" value="@Model.Request.ArchidektInputSource" />
                <input type="hidden" name="Direction" value="@Model.Request.Direction" />
                <input type="hidden" name="CategorySyncMode" value="@Model.Request.CategorySyncMode" />
                <input type="hidden" name="MoxfieldUrl" value="@Model.Request.MoxfieldUrl" />
                <input type="hidden" name="MoxfieldText" value="@Model.Request.MoxfieldText" />
                <input type="hidden" name="ArchidektUrl" value="@Model.Request.ArchidektUrl" />
                <input type="hidden" name="ArchidektText" value="@Model.Request.ArchidektText" />
                <input type="hidden" name="Mode" value="@Model.Request.Mode" />
                <div class="panel-heading">
                    <div>
                        <h2>Printing Conflicts</h2>
                        <p>@targetName printings stay in place unless you generate a manual checklist for swapping them afterward.</p>
                    </div>
                    <div class="conflict-actions">
                        <button type="button" class="copy-button" data-select-all-choice="@PrintingChoice.KeepArchidekt">Select All @targetName</button>
                        <button type="button" class="copy-button" data-select-all-choice="@PrintingChoice.UseMoxfield">Select All @sourceName</button>
                        <button type="submit" class="run-button">Generate Printing Swap Checklist</button>
                    </div>
                </div>
                <table class="conflicts-table">
                    <thead>
                        <tr>
                            <th>Card</th>
                            <th>@targetName</th>
                            <th>@sourceName</th>
                            <th>Use</th>
                        </tr>
                    </thead>
                    <tbody>
                    @foreach (var conflict in Model.Diff.PrintingConflicts)
                    {
                        <tr>
                            <td>@conflict.CardName</td>
                            <td>(@conflict.ArchidektVersion.SetCode) @conflict.ArchidektVersion.CollectorNumber [@conflict.ArchidektVersion.Category]</td>
                            <td>(@conflict.MoxfieldVersion.SetCode) @conflict.MoxfieldVersion.CollectorNumber</td>
                            <td class="choice-cell">
                                <label><input type="radio" name="Resolutions[@conflict.CardName]" value="@PrintingChoice.KeepArchidekt" checked /> @targetName</label>
                                <label><input type="radio" name="Resolutions[@conflict.CardName]" value="@PrintingChoice.UseMoxfield" /> @sourceName</label>
                            </td>
                        </tr>
                    }
                    </tbody>
                </table>
            </form>
        }

        @if (!string.IsNullOrWhiteSpace(Model.SwapChecklistText))
        {
            <section class="result-panel">
                <div class="panel-heading">
                    <div>
                        <h2>Swap Checklist</h2>
                        <p>Use this as your checklist for changing printings in @targetName after import.</p>
                    </div>
                    <button type="button" class="copy-button" data-copy-target="swap-output">Copy</button>
                </div>
                <textarea id="swap-output" readonly spellcheck="false">@Model.SwapChecklistText</textarea>
            </section>
        }

        <details class="result-panel">
            <summary>How to import safely</summary>
            <pre>@Model.InstructionsText</pre>
        </details>
    </section>
}
</noscript>
