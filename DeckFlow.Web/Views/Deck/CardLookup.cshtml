@model DeckFlow.Web.Models.CardLookupViewModel
@{
    ViewData["Title"] = "Card Lookup";
}

<section class="hero">
    <h1>Card Lookup</h1>
    <p class="lede">Look up a single card's Oracle text and WOTC rulings, or paste a list (desktop) and download the full Scryfall text as <code>.txt</code> or <code>.json</code>.</p>
</section>

@await Html.PartialAsync("_BusyIndicator")
@await Html.PartialAsync("_DeckToolTabs", Model.ActiveTab)

<div class="error-banner @(string.IsNullOrWhiteSpace(Model.ErrorMessage) ? "hidden" : string.Empty)" role="alert">
    @Model.ErrorMessage
</div>

<div class="toolbar card-lookup-mode-picker desktop-only" role="group" aria-label="Card lookup mode" data-card-lookup-mode-picker>
    <button type="button" class="clear-cache-button is-active" data-card-lookup-mode-button="single" aria-pressed="true">Single Card</button>
    <button type="button" class="clear-cache-button" data-card-lookup-mode-button="list" aria-pressed="false">Card List (download)</button>
</div>

<section class="card-lookup-mode-panel" data-card-lookup-mode-panel="single">
    <div class="field-grid">
        <div class="field">
            <label for="card-lookup-single-name">Card name</label>
            <div class="autocomplete-anchor">
                <input id="card-lookup-single-name" type="text" spellcheck="false" autocomplete="off"
                       placeholder="e.g. Sol Ring" data-card-lookup-single-input />
            </div>
        </div>
    </div>

    <div class="toolbar">
        <button type="button" class="run-button" data-card-lookup-single-submit>Look Up</button>
        <button type="button" class="clear-cache-button" data-card-lookup-single-clear>Clear</button>
    </div>

    <div class="error-banner hidden" role="alert" data-card-lookup-single-error></div>

    <div class="card-lookup-grid">
        <section class="result-panel hidden card-lookup-grid__oracle" data-card-lookup-single-result>
            <div class="panel-heading">
                <div>
                    <h2>Card</h2>
                    <p data-card-lookup-single-name-label></p>
                </div>
                <button type="button" class="copy-button copy-button--icon" data-copy-target="card-lookup-single-output" aria-label="Copy oracle text" title="Copy oracle text">
                    <span aria-hidden="true">&#128203;</span>
                </button>
            </div>
            <pre id="card-lookup-single-output" class="oracle-text" data-card-lookup-single-output></pre>
            <p class="mode-note">
                <a data-card-lookup-ask-judge-link href="@Url.Content("~/judge-questions")">Ask a rules question about this card &rarr;</a>
            </p>
        </section>

        <section class="result-panel hidden card-lookup-grid__rail" data-card-lookup-single-mechanics-panel>
            <div class="panel-heading">
                <div>
                    <h2>Keyword Rules</h2>
                    <p data-card-lookup-single-mechanics-label></p>
                </div>
            </div>
            <div class="stack" data-card-lookup-single-mechanics></div>
        </section>
    </div>
</section>

<section class="card-lookup-mode-panel desktop-only hidden" data-card-lookup-mode-panel="list">
    <div class="warning-banner">
        Optional leading quantities such as <code>1 Sol Ring</code> are allowed and will be preserved in the downloaded output.
    </div>

    <div class="info-banner">
        Scryfall live lookups are capped at 100 cards per submission and sent in collection batches to reduce request volume.
    </div>

    <form method="post" action="@Url.Content("~/card-lookup/download")" class="deck-form" data-cache-key="card-lookup" data-busy-title="Looking up cards" data-busy-message="Checking submitted card names against Scryfall." data-busy-hold-final-step="true">
        @Html.AntiForgeryToken()
        <div class="field-grid">
            <label class="field">
                <span>Card list</span>
                <textarea name="CardList" spellcheck="false" placeholder="Sol Ring&#10;Arcane Signet&#10;1 Guardian Project">@Model.Request.CardList</textarea>
            </label>
        </div>
        <div class="mode-note card-lookup-editor-note">
            <div>
                <strong>Optional line editor</strong>
                <div>Convert the pasted text into editable rows with Scryfall look-ahead on each card-name field. Edits sync back into the textarea above.</div>
            </div>
            <div class="card-lookup-editor-actions">
                <button type="button" class="clear-cache-button" data-card-lookup-build-lines>Convert To Editable Lines</button>
                <button type="button" class="clear-cache-button hidden" data-card-lookup-add-line>Add Line</button>
            </div>
        </div>
        <div class="card-lookup-line-editor hidden" data-card-lookup-line-editor></div>
        <div class="mode-note">
            <span data-verify-lines-count>0/100 lines</span>
        </div>
        <div class="error-banner hidden" role="alert" data-verify-lines-error></div>
        <p class="mode-note">
            Each Download button runs the Scryfall lookup on the list above and saves the enriched card text to a file. For inline results on screen, use <strong>Single Card</strong> mode.
        </p>
        <div class="toolbar">
            <button type="submit" class="run-button" formaction="@Url.Content("~/card-lookup/download")">Download .txt</button>
            <button type="submit" class="clear-cache-button" formaction="@Url.Content("~/card-lookup/download-json")">Download .json</button>
            <button type="button" class="clear-cache-button" data-clear-cache data-clear-href="@Url.Content("~/card-lookup")">Clear</button>
        </div>
    </form>
</section>

@section Scripts {
    <script src="~/js/deck-sync.js" asp-append-version="true"></script>
    <script src="~/js/card-lookup.js" asp-append-version="true"></script>
}
