@{
    var themeOptions = new (string FileName, string Label)[]
    {
        ("site.css", "Classic"),
        ("site-azorius.css", "Azorius (WU)"),
        ("site-dimir.css", "Dimir (UB)"),
        ("site-rakdos.css", "Rakdos (BR)"),
        ("site-gruul.css", "Gruul (RG)"),
        ("site-selesnya.css", "Selesnya (GW)"),
        ("site-orzhov.css", "Orzhov (WB)"),
        ("site-izzet.css", "Izzet (UR)"),
        ("site-golgari.css", "Golgari (BG)"),
        ("site-boros.css", "Boros (RW)"),
        ("site-simic.css", "Simic (GU)"),
        ("site-bant.css", "Bant (GWU)"),
        ("site-abzan.css", "Abzan (WBG)"),
        ("site-sultai.css", "Sultai (BGU)"),
        ("site-mardu.css", "Mardu (RWB)"),
        ("site-temur.css", "Temur (GUR)"),
        ("site-esper.css", "Esper (WUB)"),
        ("site-grixis.css", "Grixis (UBR)"),
        ("site-jund.css", "Jund (BRG)"),
        ("site-naya.css", "Naya (RGW)"),
        ("site-jeskai.css", "Jeskai (URW)"),
        ("site-nyx.css", "Nyx"),
        ("site-planeswalker-dark.css", "Planeswalker Dark"),
        ("site-commander-table.css", "Commander Table"),
    };
    const string themeCookieName = "deckflow-theme";
    const string defaultThemeFileName = "site.css";
    var selectedThemeFileName = Context?.Request.Cookies.TryGetValue(themeCookieName, out var cookieTheme) == true
        && Array.Exists(themeOptions, option => string.Equals(option.FileName, cookieTheme, StringComparison.OrdinalIgnoreCase))
            ? cookieTheme
            : defaultThemeFileName;
    var defaultThemeHref = Url.Content($"~/css/{defaultThemeFileName}");
    var selectedThemeHref = Url.Content($"~/css/{selectedThemeFileName}");
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - DeckFlow</title>
    <link rel="stylesheet" href="~/css/site-common.css" asp-append-version="true" />
    <link id="theme-stylesheet" rel="stylesheet" href="@selectedThemeHref" data-default-href="@defaultThemeHref" data-default-theme="@defaultThemeFileName" data-cookie-name="@themeCookieName" />
</head>
<body data-deckflow-extension-bridge="enabled" data-deckflow-extension-install-url="@Url.Content("~/extension-install.html")">
    <a class="skip-link" href="#main-content">Skip to main content</a>
    <div class="page-shell">
        <div class="page-frame">
            <header class="page-header">
                <a class="page-brand" href="@Url.Content("~/")" aria-label="DeckFlow home">DeckFlow</a>
                <nav class="page-nav" aria-label="Primary">
                    <a class="page-nav__link" href="@Url.Content("~/help")">Help</a>
                </nav>
                <div class="theme-picker">
                    <label class="theme-picker__label" for="theme-picker">Theme</label>
                    <select id="theme-picker" class="theme-picker__select" data-df-select>
                        @foreach (var themeOption in themeOptions)
                        {
                            <option value="@themeOption.FileName" data-theme-href="@Url.Content($"~/css/{themeOption.FileName}")" selected="@(themeOption.FileName == selectedThemeFileName ? "selected" : null)">@themeOption.Label</option>
                        }
                    </select>
                </div>
            </header>
            <main role="main" id="main-content" class="content-shell">
                <div class="global-job-notice hidden" data-global-job-notice>
                    <p class="global-job-notice__text" data-global-job-notice-text></p>
                    <button type="button" class="global-job-notice__close" data-global-job-notice-dismiss aria-label="Dismiss background job notice">Dismiss</button>
                </div>
                @RenderBody()
            </main>
            <footer class="page-footer">
                <a class="page-footer__link" href="@Url.Content("~/about")">About</a>
                <a class="page-footer__link page-footer__link--cta" href="@Url.Content("~/feedback")">Feedback</a>
            </footer>
            <div class="sr-only" role="status" aria-live="polite" data-copy-announcer></div>
        </div>
    </div>
    <button type="button" id="back-to-top-button" class="back-to-top-button" aria-label="Back to top" title="Back to top">
        <svg class="back-to-top-icon" aria-hidden="true" viewBox="0 0 20 20" width="20" height="20" focusable="false">
            <path d="M2.5 3.5H17.5" />
            <path d="M10 16.5V7.75" />
            <path d="M6.75 10.75 10 7.5l3.25 3.25" />
        </svg>
    </button>
    <script src="~/js/site.js" asp-append-version="true"></script>
    <script src="~/js/df-select.js" asp-append-version="true"></script>
    <script src="~/js/df-typeahead.js" asp-append-version="true"></script>
    @RenderSection("Scripts", required: false)
</body>
</html>
