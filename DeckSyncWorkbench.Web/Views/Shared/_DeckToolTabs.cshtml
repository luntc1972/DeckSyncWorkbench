@using DeckSyncWorkbench.Web.Models
@model DeckPageTab

<nav class="tab-bar" aria-label="Deck tools">
    <a class="tab-link @(Model == DeckPageTab.Sync ? "is-active" : string.Empty)" href="/">Deck Sync</a>
    <a class="tab-link @(Model == DeckPageTab.SuggestCategories ? "is-active" : string.Empty)" href="/suggest-categories">Suggest Categories</a>
    <a class="tab-link @(Model == DeckPageTab.CommanderCategories ? "is-active" : string.Empty)" href="/commander-categories">Commander Categories</a>
    <a class="tab-link @(Model == DeckPageTab.CardLookup ? "is-active" : string.Empty)" href="/card-lookup">Card Lookup</a>
    <a class="tab-link @(Model == DeckPageTab.MechanicLookup ? "is-active" : string.Empty)" href="/mechanic-lookup">Mechanic Rules</a>
</nav>
