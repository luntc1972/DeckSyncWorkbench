<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - MtgDeckStudio</title>
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>
    <div class="page-shell">
        <main role="main" class="content-shell">
            @RenderBody()
        </main>
    </div>
    <button type="button" id="back-to-top-button" class="back-to-top-button" aria-label="Back to top" title="Back to top">
        <svg class="back-to-top-icon" aria-hidden="true" viewBox="0 0 20 20" width="20" height="20" focusable="false">
            <path d="M2.5 3.5H17.5" />
            <path d="M10 16.5V7.75" />
            <path d="M6.75 10.75 10 7.5l3.25 3.25" />
        </svg>
    </button>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @RenderSection("Scripts", required: false)
</body>
</html>
