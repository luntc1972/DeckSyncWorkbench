@model DeckSyncWorkbench.Web.Models.CardLookupViewModel
@{
    var hasVerified = !string.IsNullOrWhiteSpace(Model.VerifiedText);
    var hasMissing = !string.IsNullOrWhiteSpace(Model.MissingText);
    ViewData["Title"] = "Card Lookup";
}

<section class="hero">
    <h1>Card Lookup</h1>
    <p class="lede">Paste one card per line, submit, and get back the full Scryfall text for each match plus any cards that could not be found.</p>
</section>

@await Html.PartialAsync("_BusyIndicator")
@await Html.PartialAsync("_DeckToolTabs", Model.ActiveTab)

<div class="warning-banner">
    Optional leading quantities such as <code>1 Sol Ring</code> are allowed and will be preserved in the verified output.
</div>

<div class="info-banner">
    Scryfall live lookups are capped at 100 cards per submission and sent in collection batches to reduce request volume.
</div>

<div class="error-banner @(string.IsNullOrWhiteSpace(Model.ErrorMessage) ? "hidden" : string.Empty)" role="alert">
    @Model.ErrorMessage
</div>

<form method="post" action="/card-lookup" class="deck-form" data-busy-title="Looking up cards" data-busy-message="Checking submitted card names against Scryfall." data-busy-hold-final-step="true">
    @Html.AntiForgeryToken()
    <div class="field-grid">
        <label class="field">
            <span>Card list</span>
            <textarea name="CardList" spellcheck="false" placeholder="Sol Ring&#10;Arcane Signet&#10;1 Guardian Project">@Model.Request.CardList</textarea>
        </label>
    </div>
    <div class="mode-note">
        <span data-verify-lines-count>0/100 lines</span>
    </div>
    <div class="error-banner hidden" role="alert" data-verify-lines-error></div>
    <div class="toolbar">
        <button type="submit" class="run-button">Lookup Cards</button>
        <button type="submit" class="clear-cache-button" formaction="/card-lookup/download">Download .txt</button>
    </div>
</form>

@if (hasVerified || hasMissing)
{
    <section class="stack">
        <section class="result-panel @(hasVerified ? string.Empty : "hidden")">
            <div class="panel-heading">
                <div>
                    <h2>Verified Cards</h2>
                    <p>@Model.FoundCount card(s) confirmed by Scryfall.</p>
                </div>
                <button type="button" class="copy-button" onclick="navigator.clipboard.writeText(document.getElementById('verified-cards-output').value)">Copy</button>
            </div>
            <textarea id="verified-cards-output" readonly spellcheck="false">@Model.VerifiedText</textarea>
        </section>

        <section class="result-panel @(hasMissing ? string.Empty : "hidden")">
            <div class="panel-heading">
                <div>
                    <h2>Cards With Errors</h2>
                    <p>@Model.MissingCount line(s) could not be found and are marked with an error prefix.</p>
                </div>
                <button type="button" class="copy-button" onclick="navigator.clipboard.writeText(document.getElementById('missing-cards-output').value)">Copy</button>
            </div>
            <textarea id="missing-cards-output" readonly spellcheck="false">@Model.MissingText</textarea>
        </section>
    </section>
}

@section Scripts {
    <script src="~/js/deck-sync.js" asp-append-version="true"></script>
    <script src="~/js/card-lookup.js" asp-append-version="true"></script>
}
